{
  "name": "kovix-mvp",
  "version": "1.0.0",
  "description": "Kovix MVP — multi-provider agentic Electron IDE with a 5-step state machine and end-to-end file writing.",
  "main": "main.js",
  "author": "Razisafir <engineering@kovix.app>",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "check": "node -c main.js && node -c preload.js && node -c renderer.js",
    "test": "node scripts/smoke-staging.js && node scripts/smoke-gamma.js && node scripts/smoke-zeta.js",
    "test:staging": "node scripts/smoke-staging.js",
    "test:gamma": "node scripts/smoke-gamma.js",
    "test:zeta": "node scripts/smoke-zeta.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --mac --win --linux"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Razisafir/kovix-mvp.git"
  },
  "keywords": [
    "electron",
    "llm",
    "agent",
    "openai",
    "anthropic",
    "ollama",
    "gemini",
    "openrouter"
  ],
  "bugs": {
    "url": "https://github.com/Razisafir/kovix-mvp/issues"
  },
  "homepage": "https://github.com/Razisafir/kovix-mvp#readme",
  "dependencies": {
    "monaco-editor": "^0.55.1",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.kovix.desktop",
    "productName": "Kovix",
    "copyright": "Copyright © 2026 Kovix",
    "asar": true,
    "asarUnpack": [],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "tools.js",
      "staging.js",
      "code-blocks.js",
      "monaco-loader.js",
      "index.html",
      "style.css",
      "assets/**/*",
      "settings.example.json",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,readme,*.md,*.markdown,*.ts,*.flow,*.coffee,*.jst,*.coffee.md}",
      "!node_modules/**/{test,tests,__tests__,docs,doc,examples,example,bin,scripts}/**",
      "!node_modules/**/{.github,.gitlab,.idea,.vscode}/**",
      "!node_modules/**/*.{o,a,obj,lib,dll,exe,pdb}",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kovix"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "publish": null
  }
}
